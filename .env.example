# Application
PORT=3000
NODE_ENV=development

# Database (choose postgres or sqlite)
DB_TYPE=sqlite

# --- Postgres settings (used when DB_TYPE=postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=booking_platform

# --- SQLite settings (used when DB_TYPE=sqlite) ---
DB_SQLITE_PATH=db/booking-platform.sqlite

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d
