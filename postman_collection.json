{
  "info": {
    "name": "Booking Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "serviceId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"StrongP@ssw0rd\",\n  \"name\": \"Jane Doe\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"StrongP@ssw0rd\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Deep Tissue Massage\",\n  \"description\": \"A 60 minute session\",\n  \"duration\": 60,\n  \"price\": 49.99,\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/services"
          }
        },
        {
          "name": "Get All Services",
          "request": { "method": "GET", "url": "{{baseUrl}}/services" }
        },
        {
          "name": "Get Service By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/services/{{serviceId}}" }
        },
        {
          "name": "Update Service",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 59.99\n}" },
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Delete Service",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (public)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"John Smith\",\n  \"customerEmail\": \"john@example.com\",\n  \"customerPhone\": \"+94771234567\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"bookingDate\": \"2026-08-01\",\n  \"bookingTime\": \"14:30\",\n  \"notes\": \"Please call before arriving\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings?page=1&limit=10"
          }
        },
        {
          "name": "Get Booking By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/bookings/{{bookingId}}" }
        },
        {
          "name": "Update Booking Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" },
            "url": "{{baseUrl}}/bookings/{{bookingId}}/status"
          }
        },
        {
          "name": "Cancel Booking",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/bookings/{{bookingId}}/cancel" }
        }
      ]
    }
  ]
}